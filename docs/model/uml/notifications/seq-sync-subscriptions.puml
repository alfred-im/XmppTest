@startuml seq-sync-subscriptions
' Context: notifications
' Profile: client
' Command: SyncSubscriptions
' SDD: SURF-NOTIFICATIONS-001–004
' Revision: 2026-07-19

title seq-sync-subscriptions — registrazione manifest multi-account

actor Utente
participant "UI" as UI
participant "NotificationsMachine" as NM
participant "PushPlatform" as Plat
participant "ServiceWorker" as SW
participant "Supabase" as DB

Utente -> UI : login / sessionReady / resume
UI -> NM : SyncSubscriptions(manifest)
activate NM

NM -> Plat : shouldAttemptPushSubscription?
alt permission denied o unsupported
  NM --> UI : skip
else ok
  NM -> Plat : ensureSubscription(VAPID)
  Plat -> SW : register push worker
  Plat -> SW : pushManager.subscribe
  SW --> Plat : PushSubscriptionKeys
  loop ogni account nel manifest
    NM -> DB : SubscriptionRegistered
  end
  NM --> UI : SubscriptionRegistered
end
deactivate NM

@enduml
