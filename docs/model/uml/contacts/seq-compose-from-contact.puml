@startuml seq-compose-from-contact
' Context: contacts
' SDD: PROM-PERSONAL-CONTACTS-006
' Revision: 2026-07-18

title Contacts — scorciatoia «Scrivi» da rubrica

actor User
participant "ContactsScreen" as UI
participant "ComposeService" as Compose
participant "Navigation" as Nav

User -> UI : tap icona chat su contatto

alt protocol == internal
  UI -> Compose : peerFromContact(contact)
  Compose --> UI : ChatPeer.fromProfile
  UI -> Nav : Navigator.pop(peer)
  note right of Nav
    Chiamante apre conversazione
    (stesso percorso compose)
  end note
else protocol == xmpp | matrix
  UI -> Compose : peerFromContact(contact)
  Compose --> UI : StateError\n«Indirizzo esterno non ancora supportato»
  UI -> User : SnackBar errore
end

@enduml
