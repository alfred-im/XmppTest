@startuml seq-send-optimistic
' Context: messaging
' Profile: client
' Command: SendMessage (text, gif, voice, location)
' SDD: PROM-OUTBOUND-SEND-001–004
' Revision: 2026-07-19

title seq-send-optimistic — testo / GIF / voice / location

actor Utente
participant "UI" as UI
participant "OutboundSendMachine" as OSM
participant "ConversationLoadMachine" as CLM
participant "OutboundQueue" as Q
participant "Supabase" as SB

Utente -> UI : invia contenuto
UI -> OSM : SendStarted
OSM -> Q : enqueue pending item
OSM -> CLM : OptimisticInserted\n(Ready, merge in list)

alt media (gif, voice)
  OSM -> SB : UploadMedia
  SB --> OSM : MediaUploaded
end

OSM -> SB : SendMessage / SendGif / SendVoice / SendLocation
SB --> OSM : SendAcknowledged

OSM -> Q : remove item
OSM --> UI : list updated

alt errore rete o piattaforma
  OSM -> OSM : SendFailed
  OSM -> Q : update retry metadata
  OSM --> UI : message failed
end

@enduml
