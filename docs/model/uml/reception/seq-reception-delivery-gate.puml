@startuml seq-reception-delivery-gate
' Context: reception
' Profile: platform
' SDD: SYS-RECEPTION-005–010, PROM-RECEPTION-FILTER-005
' Revision: 2026-07-19

title Reception — gate recapito nel worker delivery

participant "AccountBoundary" as AB
database "MailboxArchive\n(sender copy)" as Msg
participant "DeliveryWorker" as Worker
participant "ReceptionGate" as Gate
database "MailboxArchive\n(recipient copy)" as Recv

AB -> Msg : sender copy accepted (✓)
AB -> Worker : EnqueueDeliver

Worker -> Gate : CheckSenderAllowed

alt sender allowed
  Gate --> Worker : DeliveryGatePassed
  Worker -> Recv : RecipientCopyMaterialized
  Worker -> Msg : SenderDeliveredAtSet\n(✓✓ mittente)
else sender not allowed
  Gate --> Worker : DeliveryGateRejected
  note right of Worker
    Nessuna copia destinatario.
    Spunta doppia non valorizzata.
    Confine account già ritornato ok al mittente.
  end note
end

@enduml
