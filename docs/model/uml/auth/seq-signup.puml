@startuml seq-signup
' Context: auth
' SDD: SURF-AUTH-004, SURF-AUTH-006, SURF-AUTH-008
' Revision: 2026-07-18

title Auth — registrazione

actor User
participant "AuthScreen" as UI
participant "AuthController" as AC
participant "AuthMachine" as AM
participant "AccountManager" as Mgr
participant "AccountSession" as Sess
participant "EphemeralBootstrap" as Boot
participant "GoTrue" as GT

User -> UI : Registrati (email, username, …)
UI -> AC : signUp(...)
AC -> AM : SignUpRequested
AM --> AC : AuthOperationStarted

AC -> AC : validateEmail, username, displayName
alt validazione fallita
  AC -> AM : ValidationRejected
  AC --> UI : error
else validazione ok
  AC -> Mgr : isUsernameAvailable
  alt username occupato
    AC -> AM : AuthOperationFailed
    AC --> UI : error
  else username libero
    AC -> Mgr : openWithSignUp
    Mgr -> Sess : signUpOpenAccount
    Sess -> Boot : createBootstrapClient()\n+ EphemeralPkceStorage
    Sess -> GT : rpc is_username_available
    Sess -> GT : signUp(emailRedirectTo)
    alt email non confermata (session null)
      GT --> Sess : AuthResponse (no session)
      Sess --> AC : AuthException conferma email
      AC -> AM : AuthOperationFailed
    else session ok
      Sess -> Sess : openAccountFromAuthResponse
      Sess --> Mgr : OpenAccount
      Mgr -> Mgr : upsertAccount + _rebuildFromManifest
      Mgr --> AC : AccountSession
      AC -> AM : AuthOperationCompleted(success)
      AM --> AC : SessionEstablished
      AC --> UI : overlay chiuso
    end
  end
end

@enduml
