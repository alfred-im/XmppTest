@startuml seq-media-upload
' Context: media
' Profile: client
' Commands: SendImage, SendVideo, UploadMedia (retry)
' SDD: PROM-CHAT-MEDIA-001–007
' Revision: 2026-07-19

title seq-media-upload — foto / video con preview optimistic

actor Utente
participant "UI" as UI
participant "OutboundSendMachine" as OSM
participant "OutboundMediaCache" as Cache
participant "OutboundQueue" as Q
participant "Supabase" as SB

== Image ==

Utente -> UI : seleziona immagine
UI -> OSM : SendImage
OSM -> Cache : MediaCached
OSM --> UI : optimistic preview (pending)

OSM -> Q : MediaPersisted + enqueue
opt HEIC / normalize
  OSM --> OSM : ImageNormalized
end
OSM -> SB : UploadMedia
SB --> OSM : MediaUploaded
OSM -> SB : SendImage
SB --> OSM : SendAcknowledged
OSM -> Q : dequeue

== Video ==

Utente -> UI : seleziona video
UI -> OSM : SendVideo
OSM --> UI : optimistic preview
OSM -> Cache : MediaCached
OSM -> Q : MediaPersisted + enqueue
OSM -> SB : UploadMedia
SB --> OSM : MediaUploaded
OSM -> SB : SendVideo
SB --> OSM : SendAcknowledged
OSM -> Q : dequeue

alt failure
  OSM --> UI : MediaUploadFailed
  OSM -> Q : update failed item
end

@enduml
