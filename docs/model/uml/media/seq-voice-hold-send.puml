@startuml seq-voice-hold-send
' Context: media
' Profile: client
' Commands: RecordVoiceStart, RecordVoiceStop, SendVoice
' SDD: PROM-CHAT-MEDIA (voice), PROM-OUTBOUND-SEND
' Revision: 2026-07-19

title seq-voice-hold-send — registrazione hold-to-send

actor Utente
participant "UI" as UI
participant "OutboundSendMachine" as OSM
participant "OutboundQueue" as Q
participant "Supabase" as SB

Utente -> UI : long-press mic
UI -> OSM : RecordVoiceStart
UI --> UI : VoiceRecordingStarted

alt swipe up (lock)
  UI --> UI : VoiceRecordingLocked
  Utente -> UI : stop
  UI -> OSM : RecordVoiceStop
  UI --> UI : VoicePreviewReady
  Utente -> UI : conferma invio
else release (≥ min 1s)
  Utente -> UI : release
  UI -> OSM : RecordVoiceStop
  OSM --> UI : bytes, duration
else release (< 1s)
  UI -> OSM : RecordVoiceCancel
  UI --> UI : VoiceRecordingCancelled
end

UI -> OSM : SendVoice
OSM -> Q : persist media
OSM --> UI : optimistic voice bubble
OSM -> SB : UploadMedia
SB --> OSM : MediaUploaded
OSM -> SB : SendVoice
SB --> OSM : SendAcknowledged
OSM -> Q : dequeue

@enduml
