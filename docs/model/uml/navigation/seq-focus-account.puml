@startuml seq-focus-account
' Context: navigation
' Profile: client
' Command: FocusAccount / SwitchToAccount
' Revision: 2026-07-19

title seq-focus-account — sidebar switch

actor Utente
participant "UI" as UI
participant "NavigationMachine" as Nav
participant "MultiAccountMachine" as MAM

Utente -> UI : tap account
UI -> Nav : SwitchToAccount(userId)
Nav -> MAM : FocusAccount(userId)
MAM --> Nav : AccountFocused
Nav --> UI : InboxVisible

@enduml
