@startuml seq-focus-switch
' Context: multi-account
' Profile: client
' Command: FocusAccount
' Revision: 2026-07-19

title seq-focus-switch — cambio focus account

actor Utente
participant "UI" as UI
participant "MultiAccountMachine" as MA
participant "AccountManager" as AM

Utente -> UI : tap account
UI -> MA : FocusAccount(userId)
MA -> AM : setFocus(userId)
AM --> MA : AccountFocused
MA --> UI : focus aggiornato

@enduml
