@startuml seq-process-outbox
' Context: delivery
' Profile: platform
' Command: ProcessOutbox
' SDD: SYS-DELIVERY-011
' Revision: 2026-07-19

title seq-process-outbox — dispatcher worker

participant "AccountBoundary" as AB
database "Outbox" as OB
participant "DeliveryWorker" as DW
participant "MailboxArchive" as MSG

AB -> OB : EnqueueDeliver / EnqueueReadReceipt / EnqueueGroupErogate
AB -> DW : ProcessOutbox

DW -> OB : read event_kind

alt event_kind = read_receipt
  DW -> DW : ProcessReadReceipt
  DW -> MSG : PropagateReadReceipt
  DW -> OB : OutboxCompleted
else event_kind = group_erogate
  DW -> DW : GroupErogate
  DW -> MSG : read group archive row
  DW -> DW : ErogateGroupMessage
  DW -> OB : OutboxCompleted
else event_kind = deliver (default)
  DW -> DW : DeliverInternal
  DW -> DW : CheckSenderAllowed (reception gate)
  alt allowed
    DW -> MSG : RecipientCopyMaterialized
    DW -> MSG : SenderDeliveredAtSet
    opt destinatario è gruppo
      DW -> DW : ErogateGroupMessage
    end
    DW -> OB : OutboxCompleted
  else rejected
    DW -> OB : OutboxCompleted\n(DeliveryGateRejected)
  end
end

DW --> AB : (stessa transazione)

note over AB, DW
  Internal: sincrono nel confine account.
  Federato: consumer = bridge (stub) — vedi federation.
end note

@enduml
