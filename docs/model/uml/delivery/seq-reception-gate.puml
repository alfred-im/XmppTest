@startuml seq-reception-gate
' Context: delivery + reception
' Profile: platform
' SDD: SYS-RECEPTION-005–010
' Revision: 2026-07-19

title Reception gate — deliver internal con allow list

participant "DeliveryWorker" as DW
participant "ReceptionGate" as GATE
database "Outbox" as OB
database "MailboxArchive" as SM
database "MailboxArchive" as DM

DW -> OB : claim outbox deliver
DW -> SM : read sender copy
DW -> GATE : CheckSenderAllowed\n(owner=dest, sender=mittente)

alt allowed
  GATE --> DW : DeliveryGatePassed
  DW -> DM : RecipientCopyMaterialized
  DW -> SM : SenderDeliveredAtSet
else rejected
  GATE --> DW : DeliveryGateRejected
  note right of DW
    Nessuna copia destinatario.
    Spunta doppia mittente non valorizzata.
    Confine account già ritornato ok al mittente.
  end note
end

@enduml
